{
  "name": "@sero-ai/plugin-calc",
  "version": "0.1.1",
  "description": "Modern calculator app for Sero — Pi extension with web UI",
  "keywords": [
    "pi-package"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p ui/tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./extension/index.ts"
    ]
  },
  "sero": {
    "app": {
      "id": "calc",
      "styleIsolation": "scope",
      "name": "Calculator",
      "icon": "calculator",
      "scope": "global",
      "stateFile": ".sero/apps/calc/state.json",
      "ui": "./dist/ui/remoteEntry.js",
      "component": "CalcApp",
      "devPort": 5175
    },
    "plugin": {
      "category": "utilities",
      "tags": [
        "calculator",
        "math"
      ],
      "minSeroVersion": "0.1.0",
      "preBuilt": false
    }
  },
  "dependencies": {
    "typebox": "^1.1.37"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": ">=0.80.6",
    "@earendil-works/pi-ai": ">=0.80.6",
    "@earendil-works/pi-coding-agent": ">=0.80.6",
    "@earendil-works/pi-tui": ">=0.80.6",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@sero-ai/plugin-vite": "^0.1.0",
    "@module-federation/vite": "^1.11.0",
    "@sero-ai/app-runtime": "^0.1.3",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "clsx": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
